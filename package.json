{
  "author": "Florian Imdahl <git@ffflorian.de>",
  "description": "@ffflorian's personal configuration files",
  "devDependencies": {
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "lefthook": "2.1.9",
    "multi-semantic-release": "3.1.0",
    "prettier": "3.8.3",
    "semantic-release": "25.0.3"
  },
  "engines": {
    "node": ">= 14.10"
  },
  "name": "@ffflorian/config",
  "packageManager": "yarn@4.15.0",
  "private": true,
  "scripts": {
    "fix": "yarn workspaces foreach --all --parallel --exclude config run fix",
    "lint": "yarn workspaces foreach --all --parallel --exclude config run lint",
    "prettier": "prettier \"*.{json,md,yml,ts}\"",
    "release": "multi-semantic-release --ignore-private-packages",
    "test": "exit 0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ffflorian/config.git"
  },
  "workspaces": [
    "packages/*"
  ]
}
